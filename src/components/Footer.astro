---
import config from "@/config/config.json";
---

<footer class="relative bg-white pt-16 pb-8">
	<div class="container">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
			<!-- Company Info -->
			<div class="animate-fade-in-up" style="animation-delay: 0.1s;">
				<div class="mb-6">
					<h3 class="text-2xl font-bold text-slate-900">
						⚙️ {config.site.name}
					</h3>
				</div>
				<p class="text-lg mb-6 text-slate-600">
					{config.site.tagline}
				</p>
				<p class="text-base text-slate-400 leading-relaxed">
					Ihr zuverlässiger Partner für KFZ-Technik und
					Unfallgutachten in Neu Wulmstorf. Zertifizierter
					KFZ-Sachverständiger nach § 14 StVG und § 24 StVG.
				</p>
			</div>

			<!-- Quick Links -->
			<div class="animate-fade-in-up" style="animation-delay: 0.2s;">
				<h4 class="text-lg font-bold mb-6">
					Schnellzugriff
				</h4>
				<ul class="space-y-4">
					{["Dienstleistungen", "Über uns", "Standort", "Kontakt"].map((item, index) => (
						<li key={index}>
							<a
								href={`#${item.toLowerCase().replace("ü", "u").replace("ä", "a").replace("ö", "o")}`}
								class="group flex items-center text-slate-600 hover:text-slate-900 transition-all duration-300"
							>
								<span class="transition-transform duration-300 group-hover:translate-x-2">
									→
								</span>
								<span class="ml-2">
									{item}
								</span>
							</a>
						</li>
					))}
				</ul>
			</div>

			<!-- Contact Info -->
			<div class="animate-fade-in-up" style="animation-delay: 0.3s;">
				<h4 class="text-lg font-bold mb-6">
					Kontakt
				</h4>
				<div class="space-y-4">
					{[
						{ icon: "📍", label: `${(config.params.contact_info as any).address.street}, ${(config.params.contact_info as any).address.city}` },
						{ icon: "📞", label: (config.params.contact_info as any).phone.formatted },
						{ icon: "✉️", label: (config.params.contact_info as any).email },
					].map((item, index) => (
						<div key={index} class="group flex items-center gap-3">
							<span class="text-2xl">
								{item.icon}
							</span>
							<span class="text-slate-400 group-hover:text-slate-600 transition-colors duration-300">
								{item.label}
							</span>
						</div>
					))}
				</div>
			</div>
		</div>

		<!-- Bottom Bar -->
		<div class="pt-8 border-t border-slate-200">
			<div class="flex flex-col md:flex-row items-center justify-between gap-4">
				<p class="text-sm text-slate-400">
					&copy; 2026 {config.site.name}. Alle Rechte vorbehalten.
				</p>
				<div class="flex items-center gap-4">
					{["Zertifizierter KFZ-Sachverständiger nach § 14 StVG"].map((item, index) => (
						<span
							key={index}
							class="text-sm text-slate-400 hover:text-slate-600 transition-colors duration-300 cursor-default"
						>
							{item}
						</span>
					))}
				</div>
			</div>
		</div>
	</div>
</footer>
