---
const services = [
	{
		title: "Werkstatt & Reparatur",
		description:
			"Professionelle Reparatur für alle KFZ-Fahrzeuge. Schnell, zuverlässig und faire Preise.",
		icon: "settings",
	},
	{
		title: "Reifenwechsel & Räder",
		description:
			"Große Reifenauswahl für alle Fahrzeugtypen. Premium-Marken und schneller Wechsel vor Ort.",
		icon: "circle",
	},
	{
		title: "Unfallgutachten & Schadensregulierung",
		description:
			"Zertifizierte KFZ-Gutachter nach § 14 StVG. Schnelle Abwicklung und freundlicher Kundenservice.",
		icon: "file-text",
	},
	{
		title: "KFZ-Sachverständiger & Zertifizierungen",
		description:
			"Betreuung aller Versicherungen. Zertifizierter Sachverständiger nach § 24 StVG mit persönlicher Beratung.",
		icon: "shield-check",
	},
];
---

<section id="dienstleistungen" class="section bg-slate-50 relative">
	<div class="container">
		<!-- Section Header -->
		<div class="text-center mb-16">
			<div class="inline-block mb-4 px-4 py-2 border-b border-slate-200 pb-1">
				<span class="text-sm font-semibold text-slate-600">
					Unsere Dienstleistungen
				</span>
			</div>
			<h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-slate-900 tracking-tight">
				KFZ-Experten für Neu Wulmstorf
			</h2>
			<p class="text-lg md:text-xl text-slate-600 max-w-2xl mx-auto">
				Professionelle KFZ-Dienstleistungen: Werkstatt, Reifen, Gutachten und mehr
			</p>
		</div>

		<!-- Services Grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			{services.map((service, index) => (
				<div
					class="relative p-8 rounded-xl bg-white shadow-sm border border-slate-200 hover:shadow-md hover:border-slate-300 transition-all duration-300 animate-fade-in-up"
					style={`animation-delay: ${index * 0.1}s;`}
				>
					<!-- Content -->
					<div class="relative z-10">
						<!-- Icon -->
						<div class="inline-flex items-center justify-center w-16 h-16 mb-6 rounded-lg bg-slate-50 text-slate-900 text-3xl">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								{service.icon === "settings" && (
									<path d="M12 2C6.477 2 2 7.523 2 12s4.477 2 10 10 10S17.523 2 22 12 22 12zm5-1.993l-5 5 1.414 1.414L6.707 7.293a5.004 5.004 0 0 0-7.07-7.07l5-5a5.004 5.004 0 0 0-7.07-7.07z" />
								)}
								{service.icon === "circle" && (
									<circle cx="12" cy="12" r="10" />
								)}
								{service.icon === "file-text" && (
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2 2 4H6a2 2 0 0 0-2-2V6a2 2 0 0 0 2-2H6a2 2 0 0 0-2 2v2a2 2 0 0 0 2 2zm4 6h-6v2h6v-2zm6-10H10v12h-6v2a2 2 0 0 0 2-2 6H8a2 2 0 0 0-2-2V6a2 2 0 0 0 2-2z" />
								)}
								{service.icon === "shield-check" && (
									<path d="M12 2C6.477 2 2 7.523 2 12s4.477 2 10 10 10S17.523 2 22 12 22 12zm5-1.993l-5 5 1.414 1.414L6.707 7.293a5.004 5.004 0 0 0-7.07-7.07l5-5a5.004 5.004 0 0 0-7.07-7.07z" />
								)}
							</svg>
						</div>

						<!-- Title -->
						<h3 class="text-xl font-bold mb-4 text-slate-900">
							{service.title}
						</h3>

						<!-- Description -->
						<p class="text-slate-600 leading-relaxed mb-6">
							{service.description}
						</p>

						<!-- Arrow -->
						<div class="flex items-center text-sm font-semibold text-slate-900 group-hover:translate-x-2 transition-transform duration-300">
							Mehr erfahren →
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
