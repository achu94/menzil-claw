---
import config from "@/config/config.json";
---

<section class="relative overflow-hidden bg-white">
	<!-- Content -->
	<div class="container relative z-10 section-sm py-8 md:py-16">
		<div class="text-center">
			<!-- Subtitle -->
			<div class="inline-block mb-6">
				<span class="text-base font-medium text-slate-600 pb-1 border-b border-slate-200">
						Ihr Partner für KFZ-Technik, Unfallgutachten und Reparaturen
				</span>
			</div>

			<!-- Title -->
			<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-8 text-slate-900 tracking-tight leading-tight animate-fade-in-up">
				{config.site.name}
			</h1>

			<!-- Description -->
			<p class="text-base md:text-lg text-slate-600 leading-tight max-w-3xl mx-auto">
				Zertifizierter KFZ-Sachverständiger nach § 14 StVG und § 24 StVG.
				Professionelle Schadensregulierung in Neu Wulmstorf.
			</p>

			<!-- CTA Button -->
			<div class="flex flex-col sm:flex-row gap-4 justify-center mt-8 animate-fade-in-up" style="animation-delay: 0.4s;">
				{config.navigation_button.enable && (
					<a
						href={config.navigation_button.link}
						class="w-full sm:w-auto px-8 py-3.5 rounded-xl font-semibold bg-slate-900 text-white transition-all duration-300 md:py-2"
					>
						{config.navigation_button.label}
					</a>
				)}
			</div>
		</div>
	</div>
</section>
