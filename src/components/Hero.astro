---
import config from "@/config/config.json";
---

<section class="relative overflow-hidden bg-white">
	<!-- Content -->
	<div class="container relative z-10 section-sm py-20">
		<div class="text-center">
			<!-- Subtitle -->
			<div class="inline-block mb-6">
				<span class="text-sm font-semibold text-slate-600 border-b border-slate-200 pb-1">
					Ihr Partner für KFZ-Technik, Unfallgutachten und Reparaturen
				</span>
			</div>

			<!-- Title -->
			<h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-slate-900 tracking-tight animate-fade-in-up">
				{config.site.name}
			</h1>

			<!-- Description -->
			<p class="text-lg md:text-xl lg:text-2xl mb-12 max-w-3xl mx-auto text-slate-600 leading-relaxed animate-fade-in" style="animation-delay: 0.2s;">
				Zertifizierter KFZ-Sachverständiger nach § 14 StVG und § 24 StVG.
				Professionelle Schadensregulierung in Neu Wulmstorf.
				Schnelle Abwicklung und freundlicher Kundenservice.
			</p>

			<!-- CTA Button -->
			<div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up" style="animation-delay: 0.4s;">
				{config.navigation_button.enable && (
					<a
						href={config.navigation_button.link}
						class="px-8 py-3.5 rounded-lg font-semibold bg-black text-white shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300"
					>
						{config.navigation_button.label}
					</a>
				)}
			</div>
		</div>
	</div>
</section>
