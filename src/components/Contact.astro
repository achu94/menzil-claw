---
import config from "@/config/config.json";

interface ContactInfo {
  address: {
    street: string;
    city: string;
    country: string;
  };
  phone: {
    country_code: string;
    number: string;
    formatted: string;
  };
  email: string;
  hours: {
    monday_friday: {
      open: string;
      close: string;
    };
    saturday: {
      open: string;
      close: string;
    };
  };
  social?: {
    facebook?: string;
    instagram?: string;
    linkedin?: string;
  };
}
---

<section id="kontakt" class="section bg-white relative">
	<!-- Section Header -->
	<div class="container">
		<div class="text-center mb-16">
			<div class="inline-block mb-6">
				<span class="text-base font-medium text-slate-600 pb-1 border-b border-slate-200">
					Kontaktieren Sie uns
				</span>
			</div>
			<h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-8 text-slate-900 tracking-tight leading-tight">
				Können wir Ihnen helfen?
			</h2>
			<p class="text-base md:text-lg text-slate-600 max-w-2xl mx-auto">
				Haben Sie Fragen oder möchten Sie uns besuchen kommen?
				Rufen Sie uns an oder schreiben Sie uns eine Nachricht.
			</p>
		</div>
	</div>
	<!-- Contact Info & Form -->
	<div class="container">
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			<!-- Contact Info -->
			<div class="p-8 rounded-xl border border-slate-200 shadow-sm">
				<h3 class="text-2xl font-bold mb-8 text-slate-900">
					Kontaktinformationen
				</h3>

				<div class="space-y-8">
					{[
						{ icon: "📍", label: "Adresse", value: `${(config.params.contact_info as ContactInfo).address.street}, ${(config.params.contact_info as ContactInfo).address.city}` },
						{ icon: "📞", label: "Telefon", value: (config.params.contact_info as ContactInfo).phone.formatted },
						{ icon: "✉️", label: "E-Mail", value: (config.params.contact_info as ContactInfo).email },
						{ icon: "⏰", label: "Öffnungszeiten", value: [`Mo - Fr: ${(config.params.contact_info as ContactInfo).hours.monday_friday.open} - ${(config.params.contact_info as ContactInfo).hours.monday_friday.close} Uhr`, `Sa: ${(config.params.contact_info as ContactInfo).hours.saturday.open} - ${(config.params.contact_info as ContactInfo).hours.saturday.close} Uhr`] },
					].map((item, index) => (
						<div class="group">
							<div
								class="flex items-start gap-4 p-8 rounded-lg bg-slate-50 hover:bg-slate-100 transition-all duration-300"
								style={`animation-delay: ${0.1 + index * 0.1}s;`}
							>
								<div class="text-3xl">
									{item.icon}
								</div>
								<div>
									<h4 class="font-semibold mb-2 text-slate-900">
										{item.label}
									</h4>
									{Array.isArray(item.value) ? (
										item.value.map((v, i) => (
											<p key={i} class="text-slate-600">
												{v}
											</p>
										))
									) : (
										<p class="text-slate-600">
											{item.value}
										</p>
									)}
								</div>
							</div>
						</div>
					</div>
				))}
			</div>
			</div>

      <!-- Contact Form -->
      <div class="p-8 rounded-xl border border-slate-200 shadow-sm">
        <h3 class="text-2xl font-bold mb-8 text-slate-900">Nachricht senden</h3>
        <form class="space-y-8">
          {
            [
              {
                id: "name",
                label: "Name *",
                type: "text",
                placeholder: "Ihr Name",
              },
              {
                id: "email",
                label: "E-Mail *",
                type: "email",
                placeholder: "ihre@email.de",
              },
              {
                id: "phone",
                label: "Telefon",
                type: "tel",
                placeholder: (config.params.contact_info as ContactInfo).phone
                  .formatted,
              },
              {
                id: "subject",
                label: "Betreff *",
                type: "text",
                placeholder: "Ihr Anliegen",
              },
            ].map((field) => (
              <div>
                <label
                  for={field.id}
                  class="block mb-3 font-semibold text-slate-900"
                >
                  {field.label}
                </label>
                <input
                  type={field.type as astroHTML.JSX.HTMLInputTypeAttribute}
                  id={field.id}
                  name={field.id}
                  placeholder={field.placeholder}
                  required={field.label.includes("*")}
                  class="w-full px-5 py-4 rounded-lg border border-slate-200 bg-white focus:border-slate-900 focus:ring-4 focus:ring-slate-900/10 transition-all duration-300"
                />
              </div>
            ))
          }

          <div>
            <label
              for="message"
              class="block mb-3 font-semibold text-slate-900"
            >
              Nachricht *
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Ihre Nachricht an uns..."
              required
              class="w-full px-5 py-4 rounded-lg border border-slate-200 bg-white focus:border-slate-900 focus:ring-4 focus:ring-slate-900/10 transition-all duration-300 resize-y"
            ></textarea>
          </div>

					<button
						type="submit"
						class="w-full px-8 py-4 rounded-xl font-semibold bg-slate-900 text-white transition-all duration-300 hover:-translate-y-0.5"
					>
						<span class="flex items-center gap-2">
							Nachricht senden
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M14 2H6a2 2 0 0 1-2 2v14a2 2 0 0 1 2 2h6a2 2 0 0 1 2-2V4a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2 4H6a2 2 0 0 1 2 2V4z" />
							</svg>
						</span>
					</button>
				</form>
			</div>
		</div>
	</div>
</section>
