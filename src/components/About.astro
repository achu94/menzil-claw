---
const values = [
	{
		title: "Zertifizierung",
		description: "Zertifizierter KFZ-Sachverständiger nach § 14 StVG",
		icon: "award",
	},
	{
		title: "Erfahrung",
		description: "Über 20 Jahre Erfahrung in der KFZ-Technik",
		icon: "clock",
	},
	{
		title: "Qualität",
		description: "Professionelle Werkstatt mit zertifiziertem Personal",
		icon: "check-circle-2",
	},
	{
		title: "Schnelligkeit",
		description: "Schnelle Schadensabwicklung meist innerhalb von 7-14 Tagen",
		icon: "zap",
	},
];
---

<section id="about" class="section bg-white relative">
	<div class="container">
		<!-- Section Header -->
		<div class="text-center mb-24">
			<div class="inline-block mb-4 px-4 py-2 pb-1 border-b border-slate-200">
				<span class="text-sm font-semibold text-slate-600">
					Über uns
				</span>
			</div>
			<h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-8 text-slate-900 tracking-tight">
				Ihre KFZ-Experten in Neu Wulmstorf
			</h2>
			<p class="text-lg md:text-xl text-slate-600 max-w-2xl mx-auto">
				Bei Menzil KFZ-Experten steht das Wohl und die Sicherheit Ihres Fahrzeugs an erster Stelle.
				Wir sind Ihr zuverlässiger Partner für alle KFZ-Technik und Unfallgutachten.
			</p>
		</div>

		<!-- About Content -->
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
			<!-- Left: Mission -->
			<div class="p-8 rounded-xl bg-slate-50 border border-slate-200">
				<div class="text-5xl mb-6">🎯</div>
				<h3 class="text-2xl font-bold mb-4 text-slate-900">
					Unsere Mission
				</h3>
				<p class="text-slate-600 leading-relaxed mb-6">
					Kunden in KFZ-Fragen und -Schäden schnell und kompetent unterstützen.
					Zertifizierte KFZ-Sachverständige mit persönlicher Beratung und professioneller Schadensregulierung.
				</p>
				<div class="flex flex-wrap gap-3">
					{["Qualität", "Vertrauen", "Schnelligkeit", "Fairness"].map((item) => (
						<span class="px-3 py-1 rounded-full bg-white text-sm font-semibold text-slate-900">
							{item}
						</span>
					))}
				</div>
			</div>

			<!-- Right: Values -->
			<div class="space-y-8">
				{values.map((value, index) => (
					<div
						class="group flex items-start gap-4 p-6 rounded-xl border border-slate-200 hover:border-slate-300 transition-all duration-300"
						style={`animation-delay: ${0.1 + index * 0.1}s;`}
					>
						<div class="text-3xl">
							<span class="group-hover:scale-110 transition-transform duration-300">
								{value.icon}
							</span>
						</div>
						<div>
							<h4 class="font-semibold mb-2 text-slate-900">
								{value.title}
							</h4>
							<p class="text-sm text-slate-600">
								{value.description}
							</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
