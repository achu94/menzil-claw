---
import config from "@/config/config.json";
---

<header class="sticky top-0 z-20 backdrop-blur-md bg-white/80 border-b border-slate-100">
	<nav class="container flex items-center justify-between py-4">
		<!-- Logo -->
		<a
			href="/"
			class="text-xl font-bold text-slate-900 hover:text-slate-700 transition-all duration-300"
		>
			⚙️ {config.site.logo_text_custom}
		</a>

		<!-- Navigation -->
		<div class="hidden md:flex items-center gap-8">
			{["Dienstleistungen", "Über uns", "Standort", "Kontakt"].map((item) => (
				<a
					href={`#${item.toLowerCase().replace("ü", "u").replace("ä", "a").replace("ö", "o")}`}
					class="text-base font-medium text-slate-600 hover:text-slate-900 pb-1 border-b border-transparent hover:border-slate-200 transition-all duration-300"
				>
					{item}
				</a>
			))}
		</div>

		<!-- CTA Button -->
		{config.navigation_button.enable && (
			<a
				href={config.navigation_button.link}
				class="px-6 py-2.5 rounded-lg font-semibold bg-slate-900 text-white hover:bg-slate-800 hover:-translate-y-0.5 transition-all duration-300"
			>
				{config.navigation_button.label}
			</a>
		)}
	</nav>
</header>
