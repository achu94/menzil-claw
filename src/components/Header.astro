---
import config from "@/config/config.json";
---

<header class="sticky top-0 z-20 border-b border-gray-200 bg-white">
	<nav class="container flex items-center justify-between py-4">
		<!-- Logo -->
		<a href="/" class="text-2xl font-bold text-slate-900 transition-all duration-300">
			⚙️ {config.site.logo_text_custom}
		</a>

		<!-- Navigation -->
		<div class="hidden md:flex items-center gap-8">
			{["Dienstleistungen", "Über uns", "Standort", "Kontakt"].map((item) => (
				<a
					href={`#${item.toLowerCase()}`}
					class="text-base font-medium text-slate-600 hover:text-slate-900 border-b border-transparent hover:border-slate-200 transition-all duration-300 pb-1"
				>
					{item}
				</a>
			))}
		</div>

		<!-- CTA Button -->
		{config.navigation_button.enable && (
			<a
				href={config.navigation_button.link}
				class="px-6 py-2.5 rounded-lg font-semibold bg-black text-white shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300"
			>
				{config.navigation_button.label}
			</a>
		)}
	</nav>
</header>
